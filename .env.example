PORT=3001
PUBLIC_BASE_URL=http://localhost:3001

# Stockage
DATABASE_PATH=./data/soluxa.db
UPLOADS_PATH=./data/uploads

# Sécurité
# Génère via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=replace-with-64-hex-chars
SESSION_SECRET=replace-with-a-long-random-string

# Compte admin par défaut (créé par `npm run seed`)
ADMIN_EMAIL=admin@soluxa.ch
ADMIN_PASSWORD=changeme

# OCR images (optionnel, demande tesseract.js)
ENABLE_OCR=0
